{
  "buildCommand": "cd OCOrder && npm install && node build.mjs",
  "outputDirectory": "OCOrder/dist",
  "installCommand": "cd OCOrder && npm install",
  "framework": null,
  "env": {
    "DEMO_MODE": "true"
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
