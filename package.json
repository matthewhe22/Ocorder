{
  "name": "tocs-oc-portal",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node build.mjs --watch & node server.js",
    "build": "node build.mjs",
    "start": "node server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "redis:test:start": "redis-server --port 6399 --daemonize yes --logfile /tmp/redis-test.log --save ''",
    "redis:test:stop": "redis-cli -p 6399 shutdown nosave || true"
  },
  "dependencies": {
    "@azure/identity": "*",
    "esbuild": "^0.27.4",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^5.11.0",
    "stripe": "^17.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "*",
    "vitest": "*"
  }
}
