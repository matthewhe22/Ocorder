{
  "name": "ocorder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "start": "node server.js",
    "dev": "node build.mjs --watch & node server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:integration": "TEST_REDIS_URL=redis://localhost:6399 vitest run --reporter=verbose --sequence.concurrent=false",
    "redis:test:start": "redis-server --daemonize yes --port 6399 --logfile /tmp/redis-test.log --save \"\"",
    "redis:test:stop": "redis-cli -p 6399 shutdown nosave"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@vercel/kv": "^2.0.0",
    "nodemailer": "^6.9.14",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "pptxgenjs": "^4.0.1",
    "redis": "^5.11.0",
    "stripe": "^17",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.27.4",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
